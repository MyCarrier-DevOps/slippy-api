  "info": {
    "description": "API for CI/CD routing slips",
    "title": "Slippy API",
    "version": "1.0.0"
  },
  "openapi": "3.0.3",
  "paths": {
    "/health": {
      "get": {
        "operationId": "health-check",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthOutputBody"
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "Health check endpoint"
      }
    },
    "/logs/{correlationID}": {
      "get": {
        "description": "Returns paginated CI job logs from observability.ciJob, filterable by any column. Use the next_page URL from the response to fetch subsequent pages.",
        "operationId": "get-logs",
        "parameters": [
          {
            "description": "Correlation ID to look up logs for",
            "in": "path",
            "name": "correlationID",
            "required": true,
            "schema": {
              "description": "Correlation ID to look up logs for",
              "type": "string"
            }
          },
          {
            "description": "Page size",
            "explode": false,
            "in": "query",
            "name": "limit",
            "schema": {
              "default": 100,
              "description": "Page size",
              "format": "int64",
              "maximum": 1000,
              "minimum": 1,
              "type": "integer"
            }
          },
          {
            "description": "Pagination cursor from previous response",
            "explode": false,
            "in": "query",
            "name": "cursor",
            "schema": {
              "description": "Pagination cursor from previous response",
              "type": "string"
            }
          },
          {
            "description": "Sort by timestamp",
            "explode": false,
            "in": "query",
            "name": "sort",
            "schema": {
              "default": "desc",
              "description": "Sort by timestamp",
              "enum": [
                "asc",
                "desc"
              ],
              "type": "string"
            }
          },
          {
            "description": "Filter by log level",
            "explode": false,
            "in": "query",
            "name": "level",
            "schema": {
              "description": "Filter by log level",
              "type": "string"
            }
          },
          {
            "description": "Filter by service name",
            "explode": false,
            "in": "query",
            "name": "service",
            "schema": {
              "description": "Filter by service name",
              "type": "string"
            }
          },
          {
            "description": "Filter by component name",
            "explode": false,
            "in": "query",
            "name": "component",
            "schema": {
              "description": "Filter by component name",
              "type": "string"
            }
          },
          {
            "description": "Filter by cluster",
            "explode": false,
            "in": "query",
            "name": "cluster",
            "schema": {
              "description": "Filter by cluster",
              "type": "string"
            }
          },
          {
            "description": "Filter by cloud provider",
            "explode": false,
            "in": "query",
            "name": "cloud",
            "schema": {
              "description": "Filter by cloud provider",
              "type": "string"
            }
          },
          {
            "description": "Filter by environment",
            "explode": false,
            "in": "query",
            "name": "environment",
            "schema": {
              "description": "Filter by environment",
              "type": "string"
            }
          },
          {
            "description": "Filter by namespace",
            "explode": false,
            "in": "query",
            "name": "namespace",
            "schema": {
              "description": "Filter by namespace",
              "type": "string"
            }
          },
          {
            "description": "Filter by exact message",
            "explode": false,
            "in": "query",
            "name": "message",
            "schema": {
              "description": "Filter by exact message",
              "type": "string"
            }
          },
          {
            "description": "Filter by CI job instance",
            "explode": false,
            "in": "query",
            "name": "ci_job_instance",
            "schema": {
              "description": "Filter by CI job instance",
              "type": "string"
            }
          },
          {
            "description": "Filter by CI job type",
            "explode": false,
            "in": "query",
            "name": "ci_job_type",
            "schema": {
              "description": "Filter by CI job type",
              "type": "string"
            }
          },
          {
            "description": "Filter by build repository",
            "explode": false,
            "in": "query",
            "name": "build_repository",
            "schema": {
              "description": "Filter by build repository",
              "type": "string"
            }
          },
          {
            "description": "Filter by build image",
            "explode": false,
            "in": "query",
            "name": "build_image",
            "schema": {
              "description": "Filter by build image",
              "type": "string"
            }
          },
          {
            "description": "Filter by build branch",
            "explode": false,
            "in": "query",
            "name": "build_branch",
            "schema": {
              "description": "Filter by build branch",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetLogsOutputBody"
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            },
            "description": "Error"
          }
        },
        "security": [
          {
            "apiKey": []
          }
        ],
        "summary": "Query CI job logs by correlation ID"
      }
    },
    "/slips": {
      "post": {
        "operationId": "create-slip",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSlipInputBody"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateSlipOutputBody"
                }
              }
            },
            "description": "Created"
          },
          "default": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            },
            "description": "Error"
          }
        },
        "security": [
          {
            "writeApiKey": []
          }
        ],
        "summary": "Create a new routing slip for a push event"
      }
    },
    "/slips/by-commit/{owner}/{repo}/{commitSHA}": {
      "get": {
        "operationId": "get-slip-by-commit",
        "parameters": [
          {
            "description": "Repository owner (e.g. 'org')",
            "in": "path",
            "name": "owner",
            "required": true,
            "schema": {
              "description": "Repository owner (e.g. 'org')",
              "type": "string"
            }
          },
          {
            "description": "Repository name (e.g. 'my-service')",
            "in": "path",
            "name": "repo",
            "required": true,
            "schema": {
              "description": "Repository name (e.g. 'my-service')",
              "type": "string"
            }
          },
          {
            "description": "Git commit SHA",
            "in": "path",
            "name": "commitSHA",
            "required": true,
            "schema": {
              "description": "Git commit SHA",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {

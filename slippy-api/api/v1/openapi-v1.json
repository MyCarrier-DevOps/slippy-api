          },
          "commit_message": {
            "description": "Commit message (enables squash merge PR-based ancestry)",
            "type": "string"
          },
          "commit_sha": {
            "description": "Full git commit SHA",
            "type": "string"
          },
          "components": {
            "description": "Components to track in aggregate steps",
            "items": {
              "$ref": "#/components/schemas/ComponentDefinitionInput"
            },
            "nullable": true,
            "type": "array"
          },
          "correlation_id": {
            "description": "Unique slip identifier (from Kafka event)",
            "type": "string"
          },
          "repository": {
            "description": "Full repository name (owner/repo)",
            "type": "string"
          }
        },
        "required": [
          "correlation_id",
          "repository",
          "branch",
          "commit_sha"
        ],
        "type": "object"
      },
